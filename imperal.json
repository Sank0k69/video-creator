          "type": "string",
          "required": false
        },
        "kwargs": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "__panel__sidebar",
      "description": "Panel: Video Creator",
      "scopes": [],
      "parameters": {
        "params": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "__panel__workspace",
      "description": "Panel: Video Creator",
      "scopes": [],
      "parameters": {
        "params": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "__panel__settings",
      "description": "Panel: settings",
      "scopes": [],
      "parameters": {
        "params": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "__widget__content_calendar",
      "description": "Widget: content_calendar",
      "scopes": [],
      "parameters": {
        "params": {
          "type": "string",
          "required": true
        }
      }
    }
  ],
  "signals": [],
